<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_solar_installer_application" model="ir.sequence">
            <field name="name">SolarCell Installer Application</field>
            <field name="code">solar.installer.application</field>
            <field name="prefix">SLC-APP-</field>
            <field name="padding">5</field>
        </record>

        <record id="skill_panels" model="solar.skill">
            <field name="name">Panneaux solaires</field>
            <field name="code">panneaux_solaires</field>
            <field name="description">Installation, fixation et raccordement de panneaux photovoltaïques.</field>
            <field name="sequence">10</field>
        </record>
        <record id="skill_inverters" model="solar.skill">
            <field name="name">Onduleurs</field>
            <field name="code">onduleurs</field>
            <field name="description">Installation, configuration et maintenance des onduleurs solaires.</field>
            <field name="sequence">20</field>
        </record>
        <record id="skill_batteries" model="solar.skill">
            <field name="name">Batteries</field>
            <field name="code">batteries</field>
            <field name="description">Installation et raccordement des systèmes de stockage.</field>
            <field name="sequence">30</field>
        </record>
        <record id="skill_cabling" model="solar.skill">
            <field name="name">Câbles &amp; câblage</field>
            <field name="code">cables_cablage</field>
            <field name="description">Câblage DC/AC, chemins de câbles, connexions et protections.</field>
            <field name="sequence">40</field>
        </record>

        <record id="doc_identity" model="solar.document.requirement">
            <field name="name">Pièce d’identité</field>
            <field name="code">identity_document</field>
            <field name="document_scope">kyc</field>
            <field name="description">Carte nationale d’identité, passeport ou titre de séjour.</field>
            <field name="accepted_mimetypes">application/pdf,image/jpeg,image/png</field>
            <field name="max_size_mb">10</field>
            <field name="sequence">10</field>
        </record>
        <record id="doc_address_proof" model="solar.document.requirement">
            <field name="name">Justificatif de domicile</field>
            <field name="code">address_proof</field>
            <field name="document_scope">kyc</field>
            <field name="description">Facture d’électricité, d’eau, de gaz ou quittance de loyer.</field>
            <field name="accepted_mimetypes">application/pdf,image/jpeg,image/png</field>
            <field name="max_size_mb">10</field>
            <field name="sequence">20</field>
        </record>
        <record id="doc_kbis" model="solar.document.requirement">
            <field name="name">Extrait KBIS</field>
            <field name="code">kbis_extract</field>
            <field name="document_scope">kyb</field>
            <field name="description">Document de moins de 3 mois.</field>
            <field name="accepted_mimetypes">application/pdf</field>
            <field name="max_size_mb">10</field>
            <field name="validity_months">3</field>
            <field name="sequence">30</field>
        </record>
        <record id="doc_vat" model="solar.document.requirement">
            <field name="name">Numéro de TVA intracommunautaire</field>
            <field name="code">eu_vat_certificate</field>
            <field name="document_scope">kyb</field>
            <field name="description">Document officiel de confirmation.</field>
            <field name="accepted_mimetypes">application/pdf</field>
            <field name="max_size_mb">10</field>
            <field name="sequence">40</field>
        </record>
        <record id="doc_insurance" model="solar.document.requirement">
            <field name="name">Attestation d’assurance</field>
            <field name="code">professional_insurance</field>
            <field name="document_scope">kyb</field>
            <field name="description">Responsabilité civile professionnelle.</field>
            <field name="accepted_mimetypes">application/pdf</field>
            <field name="max_size_mb">10</field>
            <field name="sequence">50</field>
        </record>

        <record id="course_safety" model="solar.training.course">
            <field name="name">Sécurité sur les chantiers photovoltaïques</field>
            <field name="code">pv_site_safety</field>
            <field name="description">Règles de sécurité essentielles pour travailler sur les installations solaires.</field>
            <field name="sequence">10</field>
        </record>
        <record id="course_panels" model="solar.training.course">
            <field name="name">Installation de panneaux solaires</field>
            <field name="code">solar_panel_installation</field>
            <field name="description">Bonnes pratiques d’installation, fixation, raccordement et tests.</field>
            <field name="sequence">20</field>
        </record>
        <record id="course_inverters" model="solar.training.course">
            <field name="name">Installation et configuration des onduleurs</field>
            <field name="code">inverter_installation_configuration</field>
            <field name="description">Installer, configurer et maintenir les onduleurs solaires.</field>
            <field name="sequence">30</field>
        </record>
        <record id="course_batteries" model="solar.training.course">
            <field name="name">Systèmes de batteries solaires</field>
            <field name="code">solar_battery_systems</field>
            <field name="description">Installation, raccordement et maintenance des systèmes de stockage.</field>
            <field name="sequence">40</field>
        </record>
        <record id="course_cabling" model="solar.training.course">
            <field name="name">Câblage et protections électriques</field>
            <field name="code">electrical_cabling_protections</field>
            <field name="description">Câblage DC/AC, protections, mise à la terre et conformité.</field>
            <field name="sequence">50</field>
        </record>
    </data>
</odoo>
